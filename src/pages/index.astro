---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
		main {
			width: 100%;
			max-width: 1000px;
			padding: 3rem 1.5rem;
		}
		.hero {
			text-align: center;
			margin-bottom: 3rem;
			padding: 2rem 0;
		}
		.hero h1 {
			margin: 0 0 1rem 0;
			color: rgb(var(--black));
			font-size: 2.5rem;
			font-weight: 700;
			line-height: 1.2;
			letter-spacing: -0.02em;
		}
		.hero p {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 1.125rem;
			line-height: 1.6;
			max-width: 600px;
			margin: 0 auto;
		}
		.post-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 1.5rem;
			margin: 0;
			padding: 0;
			list-style: none;
		}
		.post-card {
			background: #fff;
			border: 1px solid rgb(var(--gray-light));
			border-radius: 12px;
			padding: 0;
			overflow: hidden;
			transition: all 0.2s ease;
		}
		.post-card:hover {
			box-shadow: var(--box-shadow);
			border-color: rgb(var(--accent));
			transform: translateY(-2px);
		}
		.post-card a {
			display: block;
			text-decoration: none;
			color: inherit;
		}
		.post-image {
			width: 100%;
			height: 200px;
			object-fit: cover;
			background: linear-gradient(135deg, rgb(var(--gray-light)) 0%, rgb(var(--gray-dark)) 100%);
		}
		.post-image-placeholder {
			width: 100%;
			height: 200px;
			background: linear-gradient(135deg, rgb(var(--gray-light)) 0%, rgb(var(--gray-dark)) 100%);
			display: flex;
			align-items: center;
			justify-content: center;
			color: rgb(var(--gray));
			font-size: 2rem;
		}
		.post-content {
			padding: 1.5rem;
		}
		.post-title {
			margin: 0 0 0.75rem 0;
			color: rgb(var(--black));
			font-size: 1.25rem;
			font-weight: 600;
			line-height: 1.4;
			letter-spacing: -0.01em;
		}
		.post-description {
			margin: 0 0 1rem 0;
			color: rgb(var(--gray));
			font-size: 0.9375rem;
			line-height: 1.6;
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}
		.post-meta {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			padding-top: 1rem;
			border-top: 1px solid rgb(var(--gray-light));
		}
		.post-date {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.8125rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 0.05em;
		}
		.post-card:hover .post-title {
			color: rgb(var(--accent));
		}
		@media (max-width: 768px) {
			main {
				padding: 2rem 1rem;
			}
			.hero h1 {
				font-size: 2rem;
			}
			.hero p {
				font-size: 1rem;
			}
			.post-grid {
				grid-template-columns: 1fr;
				gap: 1rem;
			}
		}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>📝 Blog Pintar</h1>
				<p>Coding, teknologi, dan random thoughts seputar kehidupan digital.</p>
			</div>
			<ul class="post-grid">
				{posts.map((post) => (
					<li class="post-card">
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage ? (
								<Image
									width={640}
									height={320}
									src={post.data.heroImage}
									alt=""
									class="post-image"
								/>
							) : (
								<div class="post-image-placeholder">📚</div>
							)}
							<div class="post-content">
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-description">{post.data.description}</p>
								<div class="post-meta">
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
