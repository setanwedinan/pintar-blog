---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

const title = 'Pre-Market Radar · USD/IDR';
const description = 'Daily FX intelligence dashboard for USD/IDR currency pair';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
				margin: 0;
			}
			iframe {
				width: 100%;
				height: calc(100vh - 60px);
				border: none;
				display: block;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<iframe src="/premarket-radar.html"></iframe>
		</main>
	</body>
</html>
