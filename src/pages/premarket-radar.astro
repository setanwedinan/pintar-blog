---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { getCollection, render } from 'astro:content';

const radarContent = (await getCollection('blog')).find(item => item.id === 'premarket-radar');

const title = 'Pre-Market Radar · USD/IDR';
const description = 'Daily FX intelligence dashboard for USD/IDR currency pair';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 20px;
			}
			article {
				max-width: 740px;
				margin: 0 auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>{title}</h1>
				<p>{description}</p>
				<hr />
				{radarContent ? (
					await render(radarContent)
				) : (
					<p>Dashboard sedang dimuat...</p>
				)}
			</article>
		</main>
	</body>
</html>
