---
import { getCollection, render } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'

const title = 'Pre-Market Radar · USD/IDR'
const description = 'Daily FX intelligence dashboard for USD/IDR currency pair'

const allPosts = await getCollection('blog')
const radarEntry = allPosts
  .filter(p => p.id.startsWith('usdidr-report-'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0]

const { Content } = radarEntry ? await render(radarEntry) : { Content: null }
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <h1>{title}</h1>
      <p>{description}</p>
      <hr />
      <div class="prose">
        {Content ? <Content /> : <p>Tidak ada data radar tersedia.</p>}
      </div>
    </main>
    <Footer />
  </body>
</html>
